{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=salio;Username=salio;Password=CHANGE_ME_STRONG_PASSWORD"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_AT_LEAST_64_CHAR_RANDOM_SECRET_STORED_IN_ENV_OR_SECRET_MANAGER",
    "Issuer": "Salio",
    "Audience": "SalioClient",
    "AccessTokenLifetimeMinutes": 30,
    "RefreshTokenLifetimeDays": 30
  },
  "Database": {
    "AutoMigrate": false,
    "AutoSeed": false
  },
  "Cors": {
    "Origins": [
      "https://CHANGE_ME_YOUR_FRONTEND_DOMAIN.com"
    ]
  },
  "Swagger": {
    "Enabled": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": ".\\logs\\salio-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
