{
  "info": {
    "name": "Salio Sales AI API",
    "_postman_id": "salio-crm-api-v1",
    "description": "Toàn bộ endpoints của Salio CRM API v1.\n\n**Cách dùng:**\n1. Đặt biến `baseUrl` = `https://salio.codeonlabs.vn` (hoặc `http://localhost:5080` khi dev)\n2. Gọi **Auth / Login** — accessToken sẽ tự động được lưu vào biến `accessToken`\n3. Mọi request khác tự dùng token đó qua Authorization header",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "https://salio.codeonlabs.vn", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "companyId",    "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "contactId",    "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "dealId",       "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "pipelineId",   "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "stageId",      "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "productId",    "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "taskId",       "value": "00000000-0000-0000-0000-000000000000", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  body.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "    console.log('✅ Token saved. Expires:', body.data.accessExpiresAt);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"orgSlug\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "description": "Đăng nhập bằng email + password. accessToken & refreshToken tự động lưu vào biến collection."
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    console.log('✅ Registered userId:', pm.response.json().data);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Nguyễn Văn A\",\n  \"orgName\": \"Công ty TNHH ABC\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "description": "Đăng ký user mới + tạo organization mới. Trả về userId."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  body.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "    console.log('✅ Token refreshed.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh"] },
            "description": "Dùng refresh token để lấy access token mới (token rotation)."
          }
        }
      ]
    },
    {
      "name": "❤️ Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/health", "host": ["{{baseUrl}}"], "path": ["api","v1","health"] },
            "description": "Kiểm tra server đang chạy. Không cần auth."
          }
        }
      ]
    },
    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Get Me (thông tin bản thân)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"] },
            "description": "Lấy thông tin user đang đăng nhập, org, và danh sách roles."
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","users"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "search",   "value": "", "disabled": true },
                { "key": "isActive", "value": "true", "disabled": true }
              ]
            },
            "description": "Liệt kê user thuộc org hiện tại. Yêu cầu permission: settings.users / view."
          }
        }
      ]
    },
    {
      "name": "🏢 Organizations",
      "item": [
        {
          "name": "Get Current Org",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/organizations/current", "host": ["{{baseUrl}}"], "path": ["api","v1","organizations","current"] },
            "description": "Lấy thông tin organization của user đang đăng nhập."
          }
        },
        {
          "name": "Update Current Org",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tên công ty mới\",\n  \"locale\": \"vi-VN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/organizations/current", "host": ["{{baseUrl}}"], "path": ["api","v1","organizations","current"] },
            "description": "Cập nhật tên và locale của org. Yêu cầu permission: settings.organization / update."
          }
        }
      ]
    },
    {
      "name": "🏭 CRM / Companies",
      "item": [
        {
          "name": "List Companies",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/crm/companies?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","crm","companies"],
              "query": [
                { "key": "page",      "value": "1" },
                { "key": "pageSize",  "value": "20" },
                { "key": "search",    "value": "", "disabled": true },
                { "key": "industry",  "value": "", "disabled": true },
                { "key": "ownerId",   "value": "", "disabled": true },
                { "key": "sortBy",    "value": "updatedAt", "disabled": true },
                { "key": "sortDir",   "value": "desc", "disabled": true }
              ]
            },
            "description": "Tìm kiếm / lọc / phân trang danh sách công ty.\nsortBy: name | createdAt | updatedAt\nsortDir: asc | desc"
          }
        },
        {
          "name": "Get Company by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/crm/companies/{{companyId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","crm","companies","{{companyId}}"] },
            "description": "Lấy chi tiết một công ty theo ID."
          }
        },
        {
          "name": "Create Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('companyId', pm.response.json().data);",
                  "    console.log('✅ companyId saved:', pm.response.json().data);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Công ty TNHH Mẫu\",\n  \"taxCode\": \"0123456789\",\n  \"industry\": \"Technology\",\n  \"size\": \"11-50\",\n  \"website\": \"https://example.com\",\n  \"phone\": \"0901234567\",\n  \"email\": \"contact@example.com\",\n  \"address\": \"123 Nguyễn Huệ, Q1, TP.HCM\",\n  \"ownerId\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/crm/companies", "host": ["{{baseUrl}}"], "path": ["api","v1","crm","companies"] },
            "description": "Tạo công ty mới. companyId tự động lưu vào biến collection."
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{companyId}}\",\n  \"name\": \"Tên công ty cập nhật\",\n  \"taxCode\": \"0123456789\",\n  \"industry\": \"Technology\",\n  \"size\": \"51-200\",\n  \"website\": \"https://example.com\",\n  \"phone\": \"0901234567\",\n  \"email\": \"new@example.com\",\n  \"address\": \"456 Lê Lợi, Q1, TP.HCM\",\n  \"ownerId\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/crm/companies/{{companyId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","crm","companies","{{companyId}}"] },
            "description": "Cập nhật thông tin công ty. ID trong body phải khớp với ID trên URL."
          }
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/crm/companies/{{companyId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","crm","companies","{{companyId}}"] },
            "description": "Xoá mềm (soft delete) một công ty."
          }
        }
      ]
    },
