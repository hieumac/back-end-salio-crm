            },
            "url": { "raw": "{{baseUrl}}/api/v1/crm/deals", "host": ["{{baseUrl}}"], "path": ["api","v1","crm","deals"] },
            "description": "source: Inbound | Outbound | Referral | Marketing | Event | Other"
          }
        },
        {
          "name": "Move Deal Stage",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
